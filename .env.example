# Copy to .env for LOCAL use only. The public Render build ships with ENABLE_LLM=false
# and no API key, so nothing here is deployed.

# Turn on the Claude categorization fallback for unknown merchants (local only).
ENABLE_LLM=false

# Required only when ENABLE_LLM=true.
ANTHROPIC_API_KEY=

# Keyless Wikidata lookup for unknown merchants (safe on the public deploy).
# Set to false to disable all outbound enrichment calls.
ENABLE_ENRICH=true
